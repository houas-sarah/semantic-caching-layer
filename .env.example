# Copiez ce fichier vers `.env` puis remplissez la clé du fournisseur choisi.

# Fournisseur LLM utilisé en cas de Cache Miss : "groq" ou "gemini"
LLM_PROVIDER=groq

# Clé API Groq (gratuite) : https://console.groq.com/keys
GROQ_API_KEY=

# Clé API Google Gemini (gratuite) : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Seuil de similarité cosinus [0..1]. Plus haut = plus strict (moins de hits,
# mais moins de risques de servir une réponse hors sujet).
SIMILARITY_THRESHOLD=0.85

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Coût simulé d'un appel LLM (pour l'estimation des économies dans /stats)
COST_PER_LLM_CALL_USD=0.01
